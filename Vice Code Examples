============================================================
2. SIMPLE UI EXAMPLE
============================================================

CODE:

@entry
@intent("UI_ROOT")
fn main() {
    mut win: Window => ui.create(
        title => "Vice UI Rect",
        size => [640, 360],
        color => "#202020"
    );

    while (win : is_open) {
        ui.rect(pos => [40, 40], size => [180, 90], color => "#00ff88");
        ui.rect(pos => [260, 120], size => [220, 140], color => "#4477ff");
    }
}

EXPLANATION:

@intent("UI_ROOT")
- Tells runtime this is a UI application.

mut win
- Creates a mutable window object.

ui.create(...)
- Creates a window with title, size, and background color.

while (win : is_open)
- Main render loop, runs while window is open.

ui.rect(...)
- Draws a rectangle on screen:
  - pos = position
  - size = dimensions
  - color = fill color

